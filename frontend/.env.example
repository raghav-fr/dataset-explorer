# Frontend Environment Variables
# Copy this file to .env.local and fill in the values for local development.
# On Vercel, set these through the Vercel Dashboard > Project Settings > Environment Variables.

# OPTIONAL: Override the backend API base URL.
# Leave empty when running locally (the Vite dev proxy handles /api/* → localhost:8000).
# Set to your Vercel deployment URL if the frontend is deployed separately from the backend.
# Example: https://my-dataset-explorer.vercel.app
VITE_API_BASE_URL=
